      <widget class="QWidget" name="pageBiseksi">
       <property name="styleSheet">
        <string notr="true">/* === TEMA BISEKSI: ORANYE SUNRISE === */

/* Label &amp; Judul */
QLabel { color: #2d3436; }
QLabel#labelJudulBiseksi {
    font-size: 18px; font-weight: bold; color: #e17055; /* Judul Oranye */
}

/* GroupBox Container */
QGroupBox {
    border: 1px solid #fab1a0; /* Border Peach */
    border-radius: 8px; margin-top: 25px; background-color: #ffffff;
}
QGroupBox::title {
    subcontrol-origin: margin; left: 15px; color: #e17055; font-weight: bold;
}

/* Tabel */
QTableWidget {
    border: 1px solid #b2bec3; gridline-color: #dfe6e9; selection-background-color: #fab1a0;
}
QHeaderView::section {
    background-color: #fff0e6; /* Header Oranye Pucat */
    font-weight: bold; border: 1px solid #dfe6e9;
}

/* Tombol Hitung (Spesifik Biseksi) */
QPushButton#btnHitungBiseksi {
    background-color: #e17055; color: white; border-radius: 6px; padding: 8px; font-weight: bold;
}
QPushButton#btnHitungBiseksi:hover { background-color: #fab1a0; }
QPushButton#btnHitungBiseksi:pressed { background-color: #d63031; }

/* Tombol Reset &amp; Kembali */
QPushButton#btnResetBiseksi {
    border: 1px solid #d63031; color: #d63031; border-radius: 6px; padding: 5px;
}
QPushButton#btnResetBiseksi:hover { background-color: #d63031; color: white; }
QPushButton#btnKembaliBiseksi {
    border: 1px solid #b2bec3; color: #636e72; border-radius: 4px; padding: 4px;
}</string>
