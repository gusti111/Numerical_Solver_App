      <widget class="QWidget" name="pageSeidel">
       <property name="styleSheet">
        <string notr="true">/* === TEMA SEIDEL: HIJAU === */

/* Label &amp; Judul */
QLabel { color: #2d3436; }
QLabel#labelJudulSeidel {
    font-size: 18px; font-weight: bold; color: #00b894; /* Judul Hijau */
}

/* GroupBox Container */
QGroupBox {
    border: 1px solid #55efc4; /* Border Hijau Muda */
    border-radius: 8px; margin-top: 25px; background-color: #ffffff;
}
QGroupBox::title {
    subcontrol-origin: margin; left: 15px; color: #00b894; font-weight: bold;
}

/* Tabel */
QTableWidget {
    border: 1px solid #b2bec3; gridline-color: #dfe6e9; selection-background-color: #55efc4;
}
QHeaderView::section {
    background-color: #e3fff9; /* Header Hijau Pucat */
    font-weight: bold; border: 1px solid #dfe6e9;
}

/* Tombol Hitung (Spesifik Seidel) */
QPushButton#btnHitungSeidel {
    background-color: #00b894; color: white; border-radius: 6px; padding: 8px; font-weight: bold;
}
QPushButton#btnHitungSeidel:hover { background-color: #55efc4; }
QPushButton#btnHitungSeidel:pressed { background-color: #00cec9; }

/* Tombol Reset */
QPushButton#btnResetSeidel {
    border: 1px solid #d63031; color: #d63031; border-radius: 6px; padding: 5px;
}
QPushButton#btnResetSeidel:hover { background-color: #d63031; color: white; }
QPushButton#btnKembaliSeidel {
    border: 1px solid #b2bec3; color: #636e72; border-radius: 4px; padding: 4px;
}</string>
