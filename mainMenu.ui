       <property name="styleSheet">
        <string notr="true">/* === TEMA JACOBI: BIRU === */

/* Label &amp; Judul */
QLabel { color: #2d3436; }
QLabel#labelJudul {
    font-size: 18px; font-weight: bold; color: #0984e3; /* Judul Biru */
}

/* GroupBox Container */
QGroupBox {
    border: 1px solid #74b9ff; /* Border Biru Muda */
    border-radius: 8px; margin-top: 25px; background-color: #ffffff;
}
QGroupBox::title {
    subcontrol-origin: margin; left: 15px; color: #0984e3; font-weight: bold;
}

/* Tabel Input &amp; Hasil */
QTableWidget {
    border: 1px solid #b2bec3; gridline-color: #dfe6e9; selection-background-color: #74b9ff;
}
QHeaderView::section {
    background-color: #e1f0ff; /* Header Biru Pucat */
    font-weight: bold; border: 1px solid #dfe6e9;
}

/* Tombol Hitung (Spesifik Jacobi) */
QPushButton#btnHitung {
    background-color: #0984e3; color: white; border-radius: 6px; padding: 8px; font-weight: bold;
}
QPushButton#btnHitung:hover { background-color: #74b9ff; }
QPushButton#btnHitung:pressed { background-color: #00cec9; }

/* Tombol Reset &amp; Kembali */
QPushButton#btnReset {
    border: 1px solid #d63031; color: #d63031; border-radius: 6px; padding: 5px;
}
QPushButton#btnReset:hover { background-color: #d63031; color: white; }
QPushButton#btnKembaliJacobi {
    border: 1px solid #b2bec3; color: #636e72; border-radius: 4px; padding: 4px;
}</string>
