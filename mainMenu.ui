       <property name="styleSheet">
        <string notr="true">/* === TEMA MENU UTAMA: MODERN DASHBOARD === */

/* 1. BACKGROUND UTAMA */
QWidget {
    background-color: #f4f7f6; /* Abu-abu sangat muda, biar mata gak sakit */
    font-family: &quot;Segoe UI&quot;, &quot;Roboto&quot;, sans-serif;
}

/* 2. JUDUL UTAMA (HEADER) */
QLabel {
    color: #2c3e50;
}
/* Asumsi ada label judul paling atas */
QLabel#judulMenu { 
    font-size: 28px;
    font-weight: bold;
    color: #2c3e50;
    padding-bottom: 20px;
}

/* === HEADER KATEGORI (Persamaan Linear &amp; Non-Linear) === */

/* 1. Style Dasar untuk Keduanya */
QLabel#persamaanLinear, QLabel#persamaanNonLinear {
    font-size: 24px;              /* Diperbesar drastis (dari 12px) biar gagah */
    font-weight: 900;             /* Extra Bold */
    padding: 15px 0px;            /* Jarak atas bawah */
    margin-bottom: 20px;          /* Jarak ke tombol di bawahnya */
    background-color: transparent;
    qproperty-alignment: AlignCenter; /* Pastikan rata tengah */
}

/* 2. HEADER KIRI: LINEAR (Nuansa Biru) */
QLabel#persamaanLinear {
    color: #0984e3;               /* Teks Biru (Matching sama tombol Jacobi) */
    border-bottom: 2px solid #eaf6ff; /* Garis tipis elegan di bawahnya */
}

/* 3. HEADER KANAN: NON-LINEAR (Nuansa Oranye) */
QLabel#persamaanNonLinear {
    color: #e17055;               /* Teks Oranye (Matching sama tombol Biseksi) */
    border-bottom: 2px solid #fff0e6; /* Garis tipis elegan di bawahnya */
}

/* 3. GROUP BOX (CARD STYLE) */
/* Ini yang bikin rapi saat Full Screen */
QGroupBox {
    background-color: #ffffff; /* Kartu Putih */
    border: 1px solid #dcdde1;
    border-radius: 15px; /* Sudut membulat */
    margin-top: 30px; /* Jarak dari atas */
    font-size: 16px; 
    font-weight: bold;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center; /* Judul di tengah */
    padding: 10px 20px;
    background-color: #ffffff;
    color: #7f8c8d; /* Warna teks judul kalem */
    border-radius: 10px;
}

/* Efek saat mouse masuk ke area GroupBox (Opsional) */
QGroupBox:hover {
    border: 2px solid #bdc3c7;
}

/* 4. TOMBOL-TOMBOL (BUTTONS) */
QPushButton {
    border-radius: 8px;
    padding: 12px;
    font-size: 16px;
    font-weight: bold;
    margin: 5px; /* Jarak antar tombol */
}

/* --- KELOMPOK LINEAR (KIRI) - TEMA BIRU --- */
/* Pastikan objectName tombol Linear-mu sesuai (btnJacobi, btnSeidel, btnJordan) */
QPushButton#btnJacobi, QPushButton#btnSeidel, QPushButton#btnJordan {
    background-color: #eaf6ff; /* Biru Pucat */
    color: #0984e3;
    border: 2px solid #eaf6ff;
}
QPushButton#btnJacobi:hover, QPushButton#btnSeidel:hover, QPushButton#btnJordan:hover {
    background-color: #0984e3; /* Jadi Biru Terang */
    color: white;
    border: 2px solid #0984e3;
}

/* --- KELOMPOK NON-LINEAR (KANAN) - TEMA ORANYE --- */
/* Pastikan objectName tombol Non-Linear-mu sesuai (btnBiseksi, btnNewton, btnRegula) */
QPushButton#btnBiseksi, QPushButton#btnNewton, QPushButton#btnRegula {
    background-color: #fff0e6; /* Oranye Pucat */
    color: #e17055;
    border: 2px solid #fff0e6;
}
QPushButton#btnBiseksi:hover, QPushButton#btnNewton:hover, QPushButton#btnRegula:hover {
    background-color: #e17055; /* Jadi Oranye Terang */
    color: white;
    border: 2px solid #e17055;
}

/* Tombol File/Menu di pojok (jika ada) */
QMenuBar {
    background-color: #ffffff;
    border-bottom: 1px solid #dcdde1;
}
QMenuBar::item:selected {
    background-color: #f1f2f6;
}

(rapikan keseluruhan tampilan halama ini, buat css nya)</string>
