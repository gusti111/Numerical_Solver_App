      <widget class="QWidget" name="pageJordan">
       <property name="styleSheet">
        <string notr="true">/* === TEMA JORDAN: UNGU === */

/* Label &amp; Judul */
QLabel { color: #2d3436; }
QLabel#labelJudulJordan {
    font-size: 18px; font-weight: bold; color: #6c5ce7; /* Judul Ungu */
}

/* GroupBox Container */
QGroupBox {
    border: 1px solid #a29bfe; /* Border Ungu Muda */
    border-radius: 8px; margin-top: 25px; background-color: #ffffff;
}
QGroupBox::title {
    subcontrol-origin: margin; left: 15px; color: #6c5ce7; font-weight: bold;
}

/* Tabel */
QTableWidget {
    border: 1px solid #b2bec3; gridline-color: #dfe6e9; selection-background-color: #a29bfe;
}
QHeaderView::section {
    background-color: #f0f0ff; /* Header Ungu Pucat */
    font-weight: bold; border: 1px solid #dfe6e9;
}

/* Tombol Hitung (Spesifik Jordan) */
QPushButton#btnHitungJordan {
    background-color: #6c5ce7; color: white; border-radius: 6px; padding: 8px; font-weight: bold;
}
QPushButton#btnHitungJordan:hover { background-color: #a29bfe; }
QPushButton#btnHitungJordan:pressed { background-color: #0984e3; }

/* Tombol Reset */
QPushButton#btnResetJordan {
    border: 1px solid #d63031; color: #d63031; border-radius: 6px; padding: 5px;
}
QPushButton#btnResetJordan:hover { background-color: #d63031; color: white; }
QPushButton#btnKembaliJordan {
    border: 1px solid #b2bec3; color: #636e72; border-radius: 4px; padding: 4px;
}</string>
       </property>
