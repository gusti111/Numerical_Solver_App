      <widget class="QWidget" name="pageRegula">
       <property name="styleSheet">
        <string notr="true">/* === TEMA REGULA FALSI: TOSCA OCEAN 🌊 === */

/* 1. LABEL &amp; JUDUL */
QLabel {
    color: #2d3436;
}
/* Judul Halaman - Tosca Gelap */
QLabel#labelJudulRegula {
    font-size: 18px;
    font-weight: bold;
    color: #0097e6; 
}

/* 2. GROUP BOX (KOTAK KONTAINER) */
QGroupBox {
    border: 1px solid #00a8ff; /* Border Biru Laut */
    border-radius: 8px;
    margin-top: 25px;
    background-color: #ffffff;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 15px;
    padding: 0 5px;
    color: #0097e6; /* Judul Group Tosca */
    font-weight: bold;
}

/* 3. TABEL HASIL */
QTableWidget {
    border: 1px solid #b2bec3;
    gridline-color: #dfe6e9;
    selection-background-color: #00a8ff; /* Warna saat baris diklik (Biru Laut) */
    selection-color: #ffffff;
}
QHeaderView::section {
    background-color: #eaf6ff; /* Header Biru Sangat Muda */
    color: #2d3436;
    font-weight: bold;
    border: 1px solid #dfe6e9;
    padding: 6px;
}

/* 4. INPUT FIELDS (Kotak Ketik) */
QLineEdit, QSpinBox {
    border: 1px solid #b2bec3;
    border-radius: 6px;
    padding: 5px;
    background-color: #ffffff;
}
/* Saat diklik jadi warna Tosca */
QLineEdit:focus, QSpinBox:focus {
    border: 2px solid #0097e6; 
    background-color: #f0faff;
}

/* ============================================
   🚀 TOMBOL UTAMA (HITUNG) - TOSCA
   ============================================ */
QPushButton#btnHitungRegula {
    background-color: #0097e6; /* Warna Dasar Tosca */
    color: white;
    border-radius: 6px;
    padding: 8px 20px;
    font-weight: bold;
    border: none;
}
QPushButton#btnHitungRegula:hover {
    background-color: #00a8ff; /* Lebih terang saat hover */
}
QPushButton#btnHitungRegula:pressed {
    background-color: #006266; /* Hijau tua saat ditekan */
}

/* ============================================
   🔄 TOMBOL RESET - MERAH BATA
   ============================================ */
QPushButton#btnResetRegula {
    background-color: #ffffff;
    color: #c23616; /* Merah Bata */
    border: 1px solid #c23616;
    border-radius: 6px;
    padding: 5px 15px;
    font-weight: bold;
}
QPushButton#btnResetRegula:hover {
    background-color: #c23616;
    color: white;
}

/* ============================================
   🔙 TOMBOL KEMBALI - ABU-ABU NETRAL
   ============================================ */
QPushButton#btnKembaliRegula {
    background-color: transparent;
    border: 1px solid #b2bec3;
    border-radius: 4px;
    color: #636e72;
    padding: 4px 10px;
}
QPushButton#btnKembaliRegula:hover {
    background-color: #dfe6e9;
    color: #2d3436;
}

/* 6. KOTAK SOLUSI (HASIL AKHIR) */
QTextEdit {
    background-color: #f8fbff; /* Biru super tipis */
    border: 1px dashed #0097e6;
    border-radius: 6px;
    font-family: &quot;Consolas&quot;, monospace;
}</string>
       </property>
