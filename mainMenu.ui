      <widget class="QWidget" name="pageNewtonRapshon">
       <property name="styleSheet">
        <string notr="true">/* === TEMA NEWTON-RAPHSON: MAGENTA SPEED ⚡ === */

/* 1. LABEL &amp; JUDUL */
QLabel {
    color: #2d3436;
}
/* Judul Halaman */
QLabel#labelJudulNewtonRaphson {
    font-size: 18px;
    font-weight: bold;
    color: #e84393; /* Judul Warna Magenta */
}

/* 2. GROUP BOX (KOTAK KONTAINER) */
QGroupBox {
    border: 1px solid #fd79a8; /* Border Pink */
    border-radius: 8px;
    margin-top: 25px;
    background-color: #ffffff;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 15px;
    padding: 0 5px;
    color: #e84393; /* Judul Group Pink */
    font-weight: bold;
}

/* 3. TABEL HASIL */
QTableWidget {
    border: 1px solid #b2bec3;
    gridline-color: #dfe6e9;
    selection-background-color: #fd79a8; /* Warna saat baris diklik (Pink) */
    selection-color: #ffffff;
}
QHeaderView::section {
    background-color: #fff5f7; /* Header Pink Sangat Muda/Pucat */
    color: #2d3436;
    font-weight: bold;
    border: 1px solid #dfe6e9;
    padding: 6px;
}

/* 4. INPUT FIELDS (Kotak Ketik) */
QLineEdit, QSpinBox {
    border: 1px solid #b2bec3;
    border-radius: 6px;
    padding: 5px;
    background-color: #ffffff;
}
/* Saat diklik jadi warna Magenta */
QLineEdit:focus, QSpinBox:focus {
    border: 2px solid #e84393; 
    background-color: #fff0f6;
}

/* ============================================
   🚀 TOMBOL UTAMA (HITUNG) - MAGENTA
   ============================================ */
QPushButton#btnHitungNewton {
    background-color: #e84393; /* Warna Dasar Magenta */
    color: white;
    border-radius: 6px;
    padding: 8px 20px;
    font-weight: bold;
    border: none;
}
QPushButton#btnHitungNewton:hover {
    background-color: #fd79a8; /* Jadi lebih terang saat didekati mouse */
}
QPushButton#btnHitungNewton:pressed {
    background-color: #d63031; /* Jadi merah saat ditekan */
}

/* ============================================
   🔄 TOMBOL RESET - MERAH OUTLINE
   ============================================ */
QPushButton#btnResetNewton {
    background-color: #ffffff;
    color: #d63031;
    border: 1px solid #d63031;
    border-radius: 6px;
    padding: 5px 15px;
    font-weight: bold;
}
QPushButton#btnResetNewton:hover {
    background-color: #d63031;
